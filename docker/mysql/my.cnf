[mysqld]
# ══════════════════════════════════════════════════════════
# MySQL 8.4 LTS 生产配置
# 标准：CIS MySQL 8.4 Benchmark Level1+Level2
# ══════════════════════════════════════════════════════════

# ── 基础路径 ──────────────────────────────────────────────
pid-file                        = /var/run/mysqld/mysqld.pid
socket                          = /var/run/mysqld/mysqld.sock
datadir                         = /var/lib/mysql
tmpdir                          = /tmp

# ── CIS 2.x 安全基线 ──────────────────────────────────────
skip-name-resolve               = ON
# 禁用DNS反解析，防欺骗，提升连接速度

skip-grant-tables               = FALSE
# CIS 2.2 显式禁止无授权启动

skip-show-database              = ON
# CIS 2.5 非授权用户不可执行 SHOW DATABASES

local-infile                    = OFF
# CIS 2.1 禁止客户端 LOAD DATA LOCAL INFILE

# symbolic-links 已在 MySQL 8.4 废弃，默认即为禁用，无需配置

secure-file-priv                = /var/lib/mysql-files
# CIS 2.4 限制文件操作目录

allow-suspicious-udfs           = OFF
# CIS 2.6 禁止加载危险 UDF

plugin-load-add=connection_control.so
connection-control=FORCE_PLUS_PERMANENT
connection-control-failed-login-attempts=FORCE_PLUS_PERMANENT
connection_control_failed_connections_threshold=5
connection_control_min_connection_delay=60000
connection_control_max_connection_delay=1920000
# 2.18实施连接延迟以减少登录失败次数

ssl_fips_mode=ON
# 2.19确保使用符合 FIPS 140-2 标准的 OpenSSL 加密

# ── CIS 6.x TLS 传输加密 ──────────────────────────────────
ssl_ca                          = /etc/mysql/certs/ca-cert.pem
ssl_cert                        = /etc/mysql/certs/server-cert.pem
ssl_key                         = /etc/mysql/certs/server-key.pem

tls_version                     = TLSv1.2,TLSv1.3
# 禁用不安全的 TLS1.0/TLS1.1

ssl_cipher                      = ECDHE-ECDSA-AES128-GCM-SHA256
tls_ciphersuites                = TLS_AES_256_GCM_SHA384

require_secure_transport        = ON
# CIS 6.3 强制所有外部TCP连接必须走 TLS
# 注意：本地 Unix Socket 连接不受此限制，entrypoint 初始化走 Socket 不受影响

log-raw = OFF
# 6.4确保“log-raw”设置为“OFF”

# ── CIS 7.x 密码策略 ──────────────────────────────────────
# validate_password.* 不能在此处配置
# 原因：组件需先通过 init.sql 的 INSTALL COMPONENT 安装
# 策略配置见 init/01-security-init.sql

default_password_lifetime       = 90
# CIS 7.3 密码90天强制过期

password_history                = 5
# 不可重用最近5个历史密码

# ── CIS 4.x 日志与审计 ────────────────────────────────────
log_error                       = /var/log/mysql/error.log
log_error_verbosity             = 2
# 2 = ERROR + WARNING

general_log                     = OFF
# 生产环境关闭，排查时临时开启：SET GLOBAL general_log=ON;
general_log_file                = /var/log/mysql/general.log

slow_query_log                  = ON
slow_query_log_file             = /var/log/mysql/slow.log
long_query_time                 = 2

log_queries_not_using_indexes   = ON
min_examined_row_limit          = 100
log_slow_admin_statements       = ON
log_throttle_queries_not_using_indexes = 10

# binlog（MySQL 8.4 默认已开启）
log_bin                         = /var/log/mysql/binlog
# binlog_format 已在 MySQL 8.4 废弃，默认即为 ROW，无需配置
binlog_row_image                = MINIMAL
binlog_expire_logs_seconds      = 2592000
sync_binlog                     = 1
max_binlog_size                 = 256M

# ── 网络与连接安全 ────────────────────────────────────────
bind-address                    = 0.0.0.0
max_connections                 = 300
max_connect_errors              = 10
# 同一来源IP连续失败10次自动屏蔽，解封：FLUSH HOST;
max_allowed_packet              = 64M
connect_timeout                 = 10
wait_timeout                    = 600
interactive_timeout             = 600
net_read_timeout                = 30
net_write_timeout               = 60

# ── InnoDB 稳定性与数据一致性 ─────────────────────────────
innodb_file_per_table           = ON
innodb_strict_mode              = ON

innodb_flush_log_at_trx_commit  = 1
# 最高安全：每次事务提交刷盘

innodb_flush_method             = O_DIRECT
# 绕过OS缓存，NVMe效果好

innodb_autoinc_lock_mode        = 2
# 高并发INSERT最优

innodb_deadlock_detect          = ON

transaction_isolation           = READ-COMMITTED
# LNMP高并发推荐，减少锁竞争

innodb_force_recovery           = 0
# 正常运行保持0，崩溃无法启动时逐步调高（1→6），修复后必须改回0

# ── MySQL 8.4 替代已移除的 innodb_log_file_size ───────────
# innodb_log_file_size 和 innodb_log_files_in_group 已在 8.4 移除
# 等效值 = 原 512M × 2组 = 1G = 1073741824 字节
innodb_redo_log_capacity        = 1073741824

innodb_log_buffer_size          = 67108864
# 64M = 67108864 字节

# ── NVMe SSD IO 调优 ──────────────────────────────────────
innodb_io_capacity              = 2000
innodb_io_capacity_max          = 6000
innodb_read_io_threads          = 4
innodb_write_io_threads         = 4
innodb_lru_scan_depth           = 1024

# ── 内存调优（8G物理内存）────────────────────────────────
innodb_buffer_pool_size         = 2147483648
# 2G = 2147483648 字节
innodb_buffer_pool_instances    = 2

# ── CPU 调优（10610U 6核12线程）──────────────────────────
innodb_thread_concurrency       = 0
thread_cache_size               = 12
thread_stack                    = 262144
# 256K = 262144 字节

# ── 缓存与表 ──────────────────────────────────────────────
table_open_cache                = 2000
table_definition_cache          = 1400
open_files_limit                = 65535
tmp_table_size                  = 67108864
max_heap_table_size             = 67108864

# ── 排序与连接缓冲（每连接独立分配） ─────────────────────
sort_buffer_size                = 4194304
join_buffer_size                = 4194304
read_buffer_size                = 2097152
read_rnd_buffer_size            = 4194304

# ── 字符集 ────────────────────────────────────────────────
character-set-server            = utf8mb4
collation-server                = utf8mb4_unicode_ci
init_connect                    = 'SET NAMES utf8mb4 COLLATE utf8mb4_unicode_ci'

# ── 系统行为 ──────────────────────────────────────────────
lower_case_table_names          = 1
# ⚠️ 只能在数据目录初始化前设置，已有数据不可更改

explicit_defaults_for_timestamp = ON

sql_mode                        = STRICT_TRANS_TABLES,NO_ZERO_IN_DATE,NO_ZERO_DATE,ERROR_FOR_DIVISION_BY_ZERO,NO_ENGINE_SUBSTITUTION

event_scheduler                 = OFF
performance_schema              = ON
performance_schema_max_table_instances = 400

# ── [client] 不配置SSL证书 ────────────────────────────────
# 原因：entrypoint 初始化阶段用此段连接临时服务器
# 若在此配置SSL，初始化时SSL尚未就绪会导致启动失败
# 应用程序请在各自的连接字符串中单独指定SSL证书路径
[client]
default-character-set           = utf8mb4

[mysql]
default-character-set           = utf8mb4
prompt                          = "MySQL [\\u@\\h:\\p \\d]> "
