# ══════════════════════════════════════════════════════════
# MySQL 环境变量配置
# ⚠️ 修改所有密码后再启动，此文件权限设为 600
# chmod 600 .env
# ══════════════════════════════════════════════════════════

# root 密码（仅限容器本地访问）
MYSQL_ROOT_PASSWORD=CHANGE_THIS_ROOT_STRONG_PASSWORD

# 业务数据库
MYSQL_DATABASE=appdb

# 应用账号（与 init.sql 中保持一致）
MYSQL_USER=appuser
MYSQL_PASSWORD=CHANGE_THIS_APP_STRONG_PASSWORD

# 监控账号（用于 healthcheck，与 init.sql 中保持一致）
MONITOR_PASSWORD=CHANGE_THIS_MONITOR_PASSWORD
